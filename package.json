{
  "name": "ludora-backend",
  "version": "0.0.1",
  "description": "",
  "author": "GANA FALL",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "prisma generate && nest build",
    "build:ci": "prisma generate && nest build",
    "format": "biome format --write .",
    "lint": "biome lint --write .",
    "check": "biome check --write .",
    "start": "nest start",
    "start:dev": "sh scripts/start-dev.sh",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "docker:dev": "docker compose -f compose.yml -f compose.dev.yml --env-file .env.dev up",
    "docker:dev:build": "docker compose -f compose.dev.yml --env-file .env.dev up --build",
    "docker:dev:down": "docker compose -f compose.yml -f compose.dev.yml --env-file .env.dev down",
    "docker:prod": "docker compose -f compose.prod.yml --env-file .env.prod up -d",
    "docker:prod:build": "docker compose -f compose.prod.yml --env-file .env.prod up -d --build",
    "docker:prod:down": "docker compose -f compose.prod.yml --env-file .env.prod down",
    "ts-check": "tsc --noEmit",
    "test": "jest",
    "generate": "pnpm exec prisma generate",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./tests/jest-e2e.json",
    "seed": "ts-node prisma/seed.ts",
    "seed:fields": "prisma generate && ts-node prisma/seedFields.ts",
    "migrate:reset": "pnpm exec prisma migrate reset",
    "db-push": "pnpm exec prisma db push",
    "studio": "pnpm exec prisma studio --browser none",
    "prepare": "husky"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.998.0",
    "@aws-sdk/s3-request-presigner": "^3.998.0",
    "@fastify/multipart": "^9.4.0",
    "@fastify/static": "^8.3.0",
    "@googlemaps/google-maps-services-js": "^3.4.2",
    "@nestjs/common": "^11.1.14",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.14",
    "@nestjs/event-emitter": "^3.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/mapped-types": "^2.1.0",
    "@nestjs/platform-fastify": "^11.1.14",
    "@nestjs/platform-socket.io": "^11.1.14",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/websockets": "^11.1.14",
    "@prisma/adapter-pg": "^7.4.1",
    "@prisma/client": "^7.4.1",
    "@prisma/client-runtime-utils": "^7.4.1",
    "@willsoto/nestjs-prometheus": "^6.0.2",
    "argon2": "^0.41.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.4",
    "fastify": "^5.7.4",
    "firebase-admin": "^13.7.0",
    "luxon": "^3.7.2",
    "nestjs-pino": "^4.6.0",
    "nodemailer": "^6.10.1",
    "pg": "^8.19.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "prisma": "^7.4.1",
    "prom-client": "^15.1.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "socket.io": "^4.8.3",
    "stripe": "^18.5.0",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.2",
    "@nestjs/cli": "^11.0.16",
    "@nestjs/schematics": "^11.0.9",
    "@nestjs/testing": "^11.1.14",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^11.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.19.13",
    "@types/pg": "^8.16.0",
    "@types/uuid": "^10.0.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "semantic-release": "^24.2.9",
    "source-map-support": "^0.5.21",
    "ts-jest": "^29.4.6",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3"
  },
  "pnpm": {
    "overrides": {
      "hono@<4.9.7": ">=4.9.7",
      "hono@>=1.1.0 <4.10.2": ">=4.10.2",
      "nodemailer@<7.0.7": ">=7.0.7",
      "valibot@>=0.31.0 <1.2.0": ">=1.2.0",
      "hono@<4.10.3": ">=4.10.3",
      "hono@<4.11.4": ">=4.11.4",
      "lodash@>=4.0.0 <=4.17.22": ">=4.17.23",
      "hono@<4.11.7": ">=4.11.7",
      "nodemailer@<=7.0.10": ">=7.0.11",
      "hono@<4.11.10": ">=4.11.10",
      "ajv@>=7.0.0-alpha.0 <8.18.0": ">=8.18.0",
      "fast-xml-parser": ">=5.3.6",
      "@isaacs/brace-expansion": ">=5.0.1",
      "qs": ">=6.14.2",
      "minimatch": ">=10.2.1",
      "test-exclude>minimatch": "3.1.2"
    }
  }
}