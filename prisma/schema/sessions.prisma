// sessions.prisma

enum TeamLabels {
  A
  B

  @@map("team_labels")
  @@schema("sessions")
}

enum GameModes {
  ONE_V_ONE
  TWO_V_TWO
  THREE_V_THREE
  FOUR_V_FOUR
  FIVE_V_FIVE
  SIX_V_SIX
  SEVEN_V_SEVEN
  EIGHT_V_EIGHT
  TEN_V_TEN
  ELEVEN_V_ELEVEN

  @@map("game_modes")
  @@schema("sessions")
}

enum SessionVisibility {
  PUBLIC
  PRIVATE

  @@map("session_visibility")
  @@schema("sessions")
}

model Sessions {
  uid      String  @id @default(cuid())
  fieldUid String  @map("field_uid")
  slotUid  String? @unique @map("slot_uid")
  title    String?

  startDate DateTime @map("start_date")
  endDate   DateTime @map("end_date")

  sport             String            @map("sport")
  gameMode          GameModes         @map("game_mode")
  level             Int               @default(0)
  creatorUid        String?           @map("creator_uid")
  maxPlayersPerTeam Int               @map("max_players_per_team")
  teamsPerGame      Int               @map("teams_per_game")
  minPlayersPerTeam Int               @map("min_players_per_team")
  description       String?
  visibility        SessionVisibility @default(PUBLIC)
  viewCount         Int               @default(0) @map("view_count")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  creator       Users?      @relation(fields: [creatorUid], references: [uid], onDelete: SetNull)
  field         Fields      @relation(fields: [fieldUid], references: [uid])
  slot          FieldSlots? @relation(fields: [slotUid], references: [uid])
  sportRelation Sports      @relation(fields: [sport], references: [name])

  sessionInvitations SessionInvitations[]
  sessionImages      SessionImages[]
  sessionTeams       SessionTeams[]
  sessionPlayers     SessionPlayers[]
  conversation       Conversations?

  @@index([fieldUid, startDate, endDate])
  @@schema("sessions")
}

model SessionInvitations {
  sessionUid  String           @map("session_uid")
  senderUid   String           @map("sender_uid")
  receiverUid String           @map("receiver_uid")
  status      InvitationStatus @default(PENDING)
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  session  Sessions @relation(fields: [sessionUid], references: [uid], onDelete: Cascade)
  sender   Users    @relation(fields: [senderUid], references: [uid], name: "senderRelation", onDelete: Cascade)
  receiver Users    @relation(fields: [receiverUid], references: [uid], name: "receiverRelation", onDelete: Cascade)

  @@unique([sessionUid, senderUid, receiverUid])
  @@index([sessionUid])
  @@index([receiverUid])
  @@map("Session_invitations")
  @@schema("sessions")
}

model SessionImages {
  uid        String   @id @default(cuid())
  sessionUid String   @map("session_uid")
  url        String
  order      Int
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  session Sessions @relation(fields: [sessionUid], references: [uid], onDelete: Cascade)

  @@map("Session_images")
  @@schema("sessions")
}

model SessionTeams {
  uid        String     @id @default(cuid())
  sessionUid String     @map("session_uid")
  teamLabel  TeamLabels @map("team_label")
  teamName   String     @map("team_name")
  createdAt  DateTime   @default(now()) @map("created_at")
  updatedAt  DateTime   @updatedAt @map("updated_at")

  session Sessions @relation(fields: [sessionUid], references: [uid], onDelete: Cascade)

  sessionPlayers SessionPlayers[]

  @@unique([sessionUid, teamLabel])
  @@map("Session_teams")
  @@schema("sessions")
}

model SessionPlayers {
  uid        String   @id @default(cuid())
  sessionUid String   @map("session_uid")
  teamUid    String   @map("team_uid")
  userUid    String?  @map("user_uid")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  session Sessions     @relation(fields: [sessionUid], references: [uid], onDelete: Cascade)
  team    SessionTeams @relation(fields: [teamUid], references: [uid])
  user    Users?       @relation(fields: [userUid], references: [uid], onDelete: SetNull)

  @@unique([sessionUid, userUid])
  @@index([sessionUid])
  @@index([userUid])
  @@map("Session_players")
  @@schema("sessions")
}
