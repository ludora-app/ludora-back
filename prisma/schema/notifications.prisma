enum NotificationType {
    FRIEND_REQUEST
    FRIEND_ACCEPTED
    SESSION_INVITATION
    SESSION_UPDATED
    SESSION_CANCELLED
    SESSION_REMINDER
    NEW_MESSAGE
    GENERAL
    EMAIL_VERIFIED

    @@map("notification_type")
    @@schema("notifications")
}

enum Platform {
    IOS
    ANDROID
    WEB

    @@map("platform")
    @@schema("notifications")
}

model Notifications {
    uid       String           @id @default(cuid())
    userUid   String           @map("user_uid")
    type      NotificationType
    title     String
    body      String
    data      Json?
    isRead    Boolean          @default(false) @map("is_read")
    createdAt DateTime         @default(now()) @map("created_at")
    readAt    DateTime?        @map("read_at")

    user Users @relation(fields: [userUid], references: [uid], onDelete: Cascade)

    @@index([userUid, isRead])
    @@index([createdAt(sort: Desc)])
    @@schema("notifications")
}

model UserPushTokens {
    uid        String    @id @default(cuid())
    userUid    String    @map("user_uid")
    token      String    @unique // token FCM
    platform   Platform? @map("platform")
    isActive   Boolean   @default(true) @map("is_active")
    lastUsedAt DateTime? @map("last_used_at")
    createdAt  DateTime  @default(now()) @map("created_at")
    updatedAt  DateTime  @updatedAt @map("updated_at")

    user Users @relation(fields: [userUid], references: [uid], onDelete: Cascade)

    @@index([userUid])
    @@index([token])
    @@map("User_push_tokens")
    @@schema("notifications")
}
