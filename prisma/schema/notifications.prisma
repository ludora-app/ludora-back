enum NotificationType {
  FRIEND_REQUEST
  FRIEND_ACCEPTED
  SESSION_INVITATION
  SESSION_UPDATED
  SESSION_CANCELLED
  SESSION_REMINDER
  NEW_MESSAGE
  GENERAL
  EMAIL_VERIFIED
  MESSAGE_SENT
  MESSAGES_READ

  @@map("notification_type")
  @@schema("notifications")
}

enum Platform {
  IOS
  ANDROID
  WEB

  @@map("platform")
  @@schema("notifications")
}

model Notifications {
  uid         String           @id @default(cuid())
  userUid     String           @map("user_uid")
  type        NotificationType
  title       String
  body        String
  data        Json?
  sentViaPush Boolean          @default(false) @map("sent_via_push")
  isRead      Boolean          @default(false) @map("is_read")
  createdAt   DateTime         @default(now()) @map("created_at")
  readAt      DateTime?        @map("read_at")

  user Users @relation(fields: [userUid], references: [uid], onDelete: Cascade)

  @@index([userUid, isRead])
  @@index([createdAt(sort: Desc)])
  @@schema("notifications")
}

model Devices {
  uid        String    @id @default(cuid())
  userUid    String    @map("user_uid")
  fcmToken   String    @unique @map("fcm_token")
  deviceId   String    @map("device_id")
  appVersion String?   @map("app_version")
  osVersion  String?   @map("os_version")
  platform   Platform? @map("platform")
  isActive   Boolean   @default(true) @map("is_active")
  lastSeenAt DateTime? @map("last_seen_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  user Users @relation(fields: [userUid], references: [uid], onDelete: Cascade)

  @@index([userUid])
  @@index([fcmToken])
  @@schema("notifications")
}
