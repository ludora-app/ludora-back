// auth.prisma

enum Provider {
  FACEBOOK
  GOOGLE
  LUDORA
  APPLE

  @@schema("auth")
}

enum Sex {
  MALE
  FEMALE
  OTHER

  @@schema("auth")
}

enum UserType {
  USER
  ADMIN
  PARTNER
  TOURNAMENT_ORGANIZER

  @@map("user_type")
  @@schema("auth")
}

enum OnBoardingStatus {
  COMPLETE
  INCOMPLETE

  @@map("on_boarding_status")
  @@schema("auth")
}

model Users {
  uid               String            @id @default(cuid())
  email             String?           @unique
  password          String?
  firstname         String?
  lastname          String?
  birthdate         DateTime?
  sex               Sex?              @map("sex")
  phone             String?
  imageUrl          String?           @map("image_url")
  bio               String?
  city              String?
  country           String            @default("FR")
  provider          Provider          @default(LUDORA)
  isConnected       Boolean           @default(true) @map("is_connected")
  stripeCustomerId  String?           @unique @map("stripe_customer_id")
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")
  isEmailVerified   Boolean           @default(false) @map("is_email_verified")
  type              UserType          @default(USER)
  onBoardingStatus  OnBoardingStatus? @default(INCOMPLETE) @map("on_boarding_status")
  isAnonymized      Boolean           @default(false) @map("is_anonymized")
  deletedAt         DateTime?         @map("deleted_at")
  appleId           String?           @unique @map("apple_id") @db.VarChar(255)
  appleRefreshToken String?           @map("apple_refresh_token") @db.VarChar(255)

  messages            Messages[]
  // Event               Events[]
  conversationMembers ConversationMembers[]
  // Get_notification    Get_notifications[]

  friendsSent     Friends[] @relation("friend1")
  friendsReceived Friends[] @relation("friend2")

  Sent_invitations     SessionInvitations[] @relation(name: "senderRelation")
  Received_invitations SessionInvitations[] @relation(name: "receiverRelation")

  sessionPlayers SessionPlayers[]

  evaluatorRating UserRatings[] @relation(name: "EvaluatorRelation")

  evaluatedRating UserRatings[] @relation(name: "EvaluatedRelation")

  sessions                Sessions[]
  payments                Payments[]
  userGlobalRatings       UserGlobalRatings[]
  emailVerifications      EmailVerification[]
  userTokens              UserTokens[]
  refreshTokens           RefreshTokens[]
  userSportPreferences    UserSportPreferences[]
  userHourPreferences     UserHourPreferences[]
  messageReceipts         MessageReceipts[]
  notifications           Notifications[]
  devices                 Devices[]
  userGameModePreferences UserGameModePreferences[]
  createdFields           Fields[]                  @relation("createdFields")
  blockedByUsers          UserBlocks[]              @relation("BlockedRelation")
  blockerUsers            UserBlocks[]              @relation("BlockerRelation")
  reportedByUsers         UserReports[]             @relation("ReportedRelation")
  reporterUsers           UserReports[]             @relation("ReporterRelation")
  tournaments             Tournaments[]
  tournamentRegistrations TournamentRegistrations[]
  tournamentStaffs        TournamentStaff[]

  @@index([createdAt])
  @@index([isConnected])
  @@schema("auth")
}

model EmailVerification {
  uid       String   @id @default(cuid())
  userUid   String   @map("user_uid")
  code      String
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user Users @relation(fields: [userUid], references: [uid], onDelete: Cascade)

  @@index([userUid])
  @@map("Email_verification")
  @@schema("auth")
}

model UserTokens {
  uid             String   @id @default(cuid())
  userUid         String   @map("user_uid")
  organisationUid String?  @map("organisation_uid")
  token           String
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  user    Users     @relation(fields: [userUid], references: [uid], onDelete: Cascade)
  partner Partners? @relation(fields: [organisationUid], references: [uid], onDelete: SetNull)

  @@index([userUid])
  @@map("User_tokens")
  @@schema("auth")
}

model RefreshTokens {
  uid             String   @id @default(cuid())
  userUid         String   @map("user_uid")
  organisationUid String?  @map("organisation_uid")
  token           String   @unique
  expiresAt       DateTime @map("expires_at")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  user    Users     @relation(fields: [userUid], references: [uid], onDelete: Cascade)
  partner Partners? @relation(fields: [organisationUid], references: [uid], onDelete: SetNull)

  @@index([userUid])
  @@map("Refresh_tokens")
  @@schema("auth")
}
