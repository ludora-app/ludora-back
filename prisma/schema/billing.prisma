// billing.prisma

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  PARTIALLY_REFUNDED
  REFUNDED
  DISPUTED

  @@map("payment_status")
  @@schema("billing")
}

enum RefundReason {
  CUSTOMER_CANCELLED
  PARTNER_CANCELLED
  TECHNICAL_ERROR
  FRAUD
  OTHER

  @@schema("billing")
}

enum RefundStatus {
  PENDING
  SUCCEEDED
  FAILED
  CANCELED

  @@schema("billing")
}

enum StripeAccountStatus {
  PENDING
  ACTIVE
  RESTRICTED
  DISABLED

  @@schema("billing")
}

enum StripeEventStatus {
  PROCESSING
  PROCESSED
  FAILED
  IGNORED

  @@schema("billing")
}

model Payments {
  uid        String @id @default(cuid())
  sessionUid String @map("session_uid")
  userUid    String @map("user_uid")
  partnerUid String @map("partner_uid")

  stripePaymentIntentId String  @unique @map("stripe_payment_intent_id") // payment_intent id
  stripeChargeId        String? @unique @map("stripe_charge_id") // for refunds
  stripeTransferId      String? @unique @map("stripe_transfer_id")

  amount                 Int // total amount in cents
  amountPlatform         Int      @default(0) @map("amount_platform") // platform commission snapshot
  amountPartner          Int      @default(0) @map("amount_partner") // partner share snapshot
  commissionRateSnapshot Decimal  @map("commission_rate_snapshot") @db.Decimal(5, 4) // commission rate snapshot
  currency               Currency @default(EUR)
  metadata               Json?

  status         PaymentStatus @default(PENDING)
  idempotencyKey String        @unique @map("idempotency_key") // anti-doublon

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  session Sessions  @relation(fields: [sessionUid], references: [uid])
  user    Users     @relation(fields: [userUid], references: [uid])
  partner Partners  @relation(fields: [partnerUid], references: [uid])
  refunds Refunds[]

  @@index([sessionUid])
  @@index([userUid])
  @@index([partnerUid])
  @@index([status])
  @@index([createdAt])
  @@schema("billing")
}

model Refunds {
  uid            String        @id @default(cuid())
  paymentUid     String        @map("payment_uid")
  stripeRefundId String        @unique @map("stripe_refund_id")
  amount         Int
  reason         RefundReason?
  status         RefundStatus  @default(PENDING)
  refundedFee    Boolean       @default(false) @map("refunded_fee")
  metadata       Json?
  // true = commission remboursée (annulation > hoursBeforeFullRefund)
  // false = commission conservée (annulation partielle)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  payment Payments @relation(fields: [paymentUid], references: [uid])

  @@index([paymentUid])
  @@schema("billing")
}

model StripeEvents {
  id          String            @id // evt_xxx
  type        String
  status      StripeEventStatus @default(PROCESSING)
  data        Json? // payload brut — indispensable pour le debug et le replay
  processedAt DateTime?         @map("processed_at")
  createdAt   DateTime          @default(now()) @map("created_at")

  @@index([type])
  @@index([status])
  @@map("Stripe_events")
  @@schema("billing")
}

model PartnerBillingConfig {
  partnerUid          String              @id @map("partner_uid")
  stripeAccountId     String?             @unique @map("stripe_account_id")
  stripeAccountStatus StripeAccountStatus @default(PENDING) @map("stripe_account_status") // "pending" | "active" | "restricted"
  // Mis à jour via webhook account.updated

  commissionRate Decimal @default(0.15) @map("commission_rate") @db.Decimal(5, 4)

  // Politique de remboursement — 3 seuils
  hoursBeforeFullRefund    Int @default(24) @map("hours_before_full_refund")
  // > 24h avant → remboursement total (commission incluse)
  hoursBeforePartialRefund Int @default(1) @map("hours_before_partial_refund")
  // entre 1h et 24h → remboursement hors commission
  // < 1h → aucun remboursement

  payoutDelayDays Int     @default(2) @map("payout_delay_days")
  // Délai avant transfer vers le partenaire
  isPayoutEnabled Boolean @default(false) @map("is_payout_enabled")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  partner Partners @relation(fields: [partnerUid], references: [uid])

  @@schema("billing")
}
