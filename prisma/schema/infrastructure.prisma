// infrastructure.prisma

enum FieldType {
  PUBLIC
  PRIVATE

  @@map("field_type")
  @@schema("infrastructure")
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED

  @@map("verification_status")
  @@schema("infrastructure")
}

model Partners {
  uid      String  @id @default(cuid())
  name     String  @unique
  imageUrl String? @map("image_url")

  zipCode    String  @map("zip_code")
  city       String
  department String?
  country    String  @default("FR")
  address    String
  latitude   Float
  longitude  Float
  phone      String
  email      String  @unique

  rank Int @default(0) @map("rank")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  userTokens    UserTokens[]
  refreshTokens RefreshTokens[]

  fields                Fields[]
  partnerSports         PartnerSports[]
  partnerBillingConfigs PartnerBillingConfig?
  payments              Payments[]

  @@index([city])
  @@index([zipCode])
  @@schema("infrastructure")
}

model Fields {
  uid        String             @id @default(cuid())
  type       FieldType          @default(PUBLIC)
  status     VerificationStatus @default(PENDING)
  partnerUid String?            @map("partner_uid")
  creatorUid String?            @map("creator_uid")
  name       String?

  zipCode      String  @map("zip_code")
  city         String
  department   String?
  country      String  @default("FR")
  address      String
  shortAddress String  @map("short_address")
  latitude     Float
  longitude    Float

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  fieldImages FieldImages[]
  fieldSlots  FieldSlots[]
  partner     Partners?     @relation(fields: [partnerUid], references: [uid], onDelete: SetNull)
  creator     Users?        @relation("createdFields", fields: [creatorUid], references: [uid], onDelete: SetNull)
  sessions    Sessions[]
  fieldSports FieldSports[]

  @@index([partnerUid])
  @@index([creatorUid])
  @@index([longitude, latitude])
  @@index([type])
  @@index([status])
  @@index([city])
  @@index([zipCode])
  @@schema("infrastructure")
}

model FieldSlots {
  uid        String    @id @default(cuid())
  fieldUid   String    @map("field_uid")
  startTime  DateTime  @map("start_time")
  endTime    DateTime  @map("end_time")
  gameMode   GameModes @default(FIVE_V_FIVE) @map("game_mode")
  price      Float
  isReserved Boolean   @default(false) @map("is_reserved")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  field   Fields    @relation(fields: [fieldUid], references: [uid], onDelete: Cascade)
  session Sessions?

  @@index([fieldUid])
  @@index([startTime, endTime])
  @@map("Field_slots")
  @@schema("infrastructure")
}

model FieldSports {
  fieldUid  String   @map("field_uid")
  sport     String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  field         Fields @relation(fields: [fieldUid], references: [uid], onDelete: Cascade)
  sportRelation Sports @relation(fields: [sport], references: [name])

  @@unique([fieldUid, sport])
  @@index([fieldUid])
  @@index([sport])
  @@map("Field_sports")
  @@schema("infrastructure")
}

model PartnerSports {
  partnerUid String   @map("partner_uid")
  sport      String
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  partner       Partners @relation(fields: [partnerUid], references: [uid], onDelete: Cascade)
  sportRelation Sports   @relation(fields: [sport], references: [name])

  @@unique([partnerUid, sport])
  @@index([partnerUid])
  @@index([sport])
  @@map("Partner_sports")
  @@schema("infrastructure")
}

model Sports {
  uid       String   @id @default(cuid())
  name      String   @unique
  imageUrl  String?  @map("image_url")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  userGlobalRatings       UserGlobalRatings[]
  partnerSports           PartnerSports[]
  userSportPreferences    UserSportPreferences[]
  userGameModePreferences UserGameModePreferences[]
  sessions                Sessions[]
  fieldSports             FieldSports[]
  userRatings             UserRatings[]

  @@schema("infrastructure")
}

model FieldImages {
  uid      String             @id @default(cuid())
  fieldUid String             @map("field_uid")
  url      String
  order    Int
  status   VerificationStatus @default(PENDING)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  field Fields @relation(fields: [fieldUid], references: [uid], onDelete: Cascade)

  @@index([fieldUid])
  @@map("Field_images")
  @@schema("infrastructure")
}
