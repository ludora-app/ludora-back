// social.prisma

enum MessageStatus {
  SENT
  DELIVERED
  READ
  DELETED

  @@map("message_status")
  @@schema("social")
}

enum MessageType {
  TEXT
  IMAGE
  VIDEO
  AUDIO

  @@map("message_type")
  @@schema("social")
}

enum ConversationType {
  PRIVATE
  GROUP
  SESSION

  @@map("conversation_type")
  @@schema("social")
}

model Conversations {
  uid                 String                @id @default(cuid())
  sessionUid          String?               @unique @map("session_uid")
  name                String?
  type                ConversationType
  createdAt           DateTime              @default(now()) @map("created_at")
  updatedAt           DateTime              @updatedAt @map("updated_at")
  messages            Messages[]
  conversationMembers ConversationMembers[]
  session             Sessions?             @relation(fields: [sessionUid], references: [uid])

  @@schema("social")
}

model Messages {
  uid             String        @id @default(cuid())
  conversationUid String        @map("conversation_uid")
  senderUid       String        @map("sender_uid")
  content         String
  globalStatus    MessageStatus @default(SENT) @map("global_status")
  type            MessageType
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  sender          Users             @relation(fields: [senderUid], references: [uid])
  conversation    Conversations     @relation(fields: [conversationUid], references: [uid])
  messageReceipts MessageReceipts[]

  @@index([conversationUid, createdAt(sort: Desc)])
  @@schema("social")
}

model MessageReceipts {
  messageUid String @map("message_uid")
  userUid    String @map("user_uid")

  status    MessageStatus @default(DELIVERED)
  updatedAt DateTime      @updatedAt @map("updated_at")

  message Messages @relation(fields: [messageUid], references: [uid], onDelete: Cascade)
  user    Users    @relation(fields: [userUid], references: [uid], onDelete: Cascade)

  @@id([messageUid, userUid])
  @@index([messageUid])
  @@map("Message_receipts")
  @@schema("social")
}

model ConversationMembers {
  conversationUid String  @map("conversation_uid")
  userUid         String  @map("user_uid")
  isAdmin         Boolean @default(false) @map("is_admin")

  conversation Conversations @relation(fields: [conversationUid], references: [uid])
  user         Users         @relation(fields: [userUid], references: [uid])

  isArchived Boolean @default(false) @map("is_archived")
  isMuted    Boolean @default(false) @map("is_muted")

  isVisible            Boolean   @default(true) @map("is_visible")
  displayMessagesAfter DateTime? @map("display_messages_after")

  joinedAt   DateTime  @default(now()) @map("joined_at")
  lastReadAt DateTime? @map("last_read_at")

  @@id([conversationUid, userUid])
  @@index([userUid, isVisible, isArchived])
  @@map("Conversation_members")
  @@schema("social")
}

model Friends {
  userUid1  String           @map("user_uid_1")
  userUid2  String           @map("user_uid_2")
  status    InvitationStatus @map("status")
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")
  user1     Users            @relation("friend1", fields: [userUid1], references: [uid], onDelete: Cascade)
  user2     Users            @relation("friend2", fields: [userUid2], references: [uid], onDelete: Cascade)

  @@id([userUid1, userUid2])
  @@unique([userUid1, userUid2])
  @@index([userUid1])
  @@index([userUid2])
  @@schema("social")
}
