// user_preferences.prisma

enum UserHourPreferenceType {
  RECURRENT
  ONE_TIME

  @@map("user_hour_preference_type")
  @@schema("user_preferences")
}

enum TimePeriod {
  MORNING
  AFTERNOON
  EVENING

  @@map("time_period")
  @@schema("user_preferences")
}

model UserSportPreferences {
  uid       String   @id @default(cuid())
  userUid   String   @map("user_uid")
  sport     String
  level     Int      @map("level")
  createdAt DateTime @default(now()) @map("created_at")

  user                    Users                     @relation(fields: [userUid], references: [uid], onDelete: Cascade)
  sportRelation           Sports                    @relation(fields: [sport], references: [name])
  userGameModePreferences UserGameModePreferences[] @relation("SportGameModes")

  @@unique([userUid, sport])
  @@index([userUid])
  @@index([sport])
  @@map("User_sports")
  @@schema("user_preferences")
}

model UserHourPreferences {
  uid        String                 @id @default(cuid())
  type       UserHourPreferenceType
  userUid    String                 @map("user_uid")
  dayOfWeek  Int                    @map("day_of_week")
  timePeriod TimePeriod             @map("time_period")
  date       DateTime?              @map("date")
  createdAt  DateTime               @default(now()) @map("created_at")

  user Users @relation(fields: [userUid], references: [uid], onDelete: Cascade)

  @@index([userUid])
  @@index([timePeriod])
  @@index([dayOfWeek])
  @@map("User_hour_preferences")
  @@schema("user_preferences")
}

model UserGameModePreferences {
  uid       String    @id @default(cuid())
  userUid   String    @map("user_uid")
  gameMode  GameModes
  sport     String
  createdAt DateTime  @default(now()) @map("created_at")

  user                Users                 @relation(fields: [userUid], references: [uid], onDelete: Cascade)
  sportRelation       Sports                @relation(fields: [sport], references: [name])
  userSportPreference UserSportPreferences? @relation("SportGameModes", fields: [userUid, sport], references: [userUid, sport], onDelete: Cascade)

  @@unique([userUid, gameMode, sport])
  @@index([userUid])
  @@index([gameMode])
  @@index([userUid, sport])
  @@map("User_game_mode_preferences")
  @@schema("user_preferences")
}
